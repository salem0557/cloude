# ── Telegram ──────────────────────────────────────────────────────────────────
# Get your bot token from @BotFather, channel ID from @userinfobot (prefix with -100 for channels)
DEALS_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff-xxxxxxxxx
DEALS_CHANNEL_ID=-1001234567890

# ── Scheduling ────────────────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=15

# ── Filters ───────────────────────────────────────────────────────────────────
# Only post deals with at least this % discount
MIN_DISCOUNT_PERCENT=15

# Price range in SAR — leave MAX_PRICE_SAR=0 for no upper limit
MIN_PRICE_SAR=0
MAX_PRICE_SAR=0

# Comma-separated category whitelist (leave empty for all categories)
# Example: ALLOWED_CATEGORIES=Phones,Computers & Laptops,TVs
ALLOWED_CATEGORIES=

# Comma-separated keywords — deal title must contain at least one (leave empty for all)
# Example: REQUIRED_KEYWORDS=iPhone,Samsung,MacBook,PlayStation
REQUIRED_KEYWORDS=

# ── Scraping ──────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=20
MAX_DEALS_PER_SITE=30

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to SQLite database file
DB_PATH=bot/deals.db

# ── Proxy (required when running from cloud/GitHub Actions) ───────────────────
# ScraperAPI routes requests through residential IPs, bypassing Cloudflare blocks.
# Free tier: 1,000 requests/month — sign up at https://www.scraperapi.com
# Without this key, the bot works from home/non-datacenter networks but NOT from GitHub Actions.
SCRAPER_API_KEY=

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to 1 to print deals to console instead of sending to Telegram
DRY_RUN=0
