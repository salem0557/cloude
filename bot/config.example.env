# Copy this file to  bot/.env  and fill in your values.
# .env is git-ignored so your keys never get committed.

# ---- mode ----
# dryrun = no real orders (safe) | testnet = fake money | live = REAL money
BOT_MODE=dryrun

# LIVE safety latch — live mode refuses to start unless this is set exactly:
# CONFIRM_LIVE=I_UNDERSTAND_THE_RISK

# ---- API keys (only for testnet/live) ----
# Create a TRADE-ONLY key with WITHDRAWALS DISABLED and IP restriction ON.
# Testnet keys come from https://testnet.binance.vision (not your real account).
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- what to trade ----
# The bot back-tests this whole basket each cycle and trades the best TOP_N.
SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT
TOP_N=3
INTERVAL=1h
HISTORY=500              # candles fetched per symbol for backtest/ML

# ---- sizing & risk ----
QUOTE_PER_TRADE=15       # quote spent per buy (e.g. USDT)
MAX_OPEN_POSITIONS=3
DAILY_LOSS_LIMIT=0       # 0 = off; e.g. 50 = halt new buys after losing 50 quote/day
PAPER_EQUITY=1000        # starting equity for dryrun accounting only

# ---- timing / self-learning ----
POLL_SECONDS=60          # how often to re-check the market
OPTIMIZE_HOURS=2         # re-tune params + retrain ML every N hours
