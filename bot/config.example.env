# Copy this file to  bot/.env  and fill in your values.
# .env is git-ignored so your keys never get committed.

# ---- cloud hosting (Railway/Render/VPS) ----
# PORT is set automatically by the host; the bot then serves a web monitor
# (dashboard + live logs) at that URL. Locally you can set it to e.g. 8000.
# PORT=8000
# DATA_DIR keeps state/models/trades on a persistent volume across redeploys.
# DATA_DIR=/data

# ---- mode ----
# dryrun = no real orders (safe) | testnet = fake money | live = REAL money
BOT_MODE=dryrun

# LIVE safety latch — live mode refuses to start unless this is set exactly:
# CONFIRM_LIVE=I_UNDERSTAND_THE_RISK

# ---- API keys (only for testnet/live) ----
# Create a TRADE-ONLY key with WITHDRAWALS DISABLED and IP restriction ON.
# Testnet keys come from https://testnet.binance.vision (not your real account).
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- what to trade ----
# Fixed basket (used when AUTO_UNIVERSE=false).
SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT
TOP_N=3

# AUTO_UNIVERSE: scan ALL tradable USDT pairs instead of the fixed basket.
# The bot discovers every USDT pair, scans them in rotating batches, keeps a
# rolling SHORTLIST of the best performers, deep-optimizes those, and trades
# the best TOP_N — without hammering Binance rate limits.
AUTO_UNIVERSE=false
MIN_QUOTE_VOLUME=5000000   # ignore illiquid coins (24h volume below this). 0 = all
MAX_UNIVERSE=250           # cap the universe size (raise toward 900 for everything)
SCAN_BATCH=30              # pairs quick-scanned per cycle (rotates through all)
SHORTLIST=12               # best scanned pairs to deep-optimize & pick TOP_N from

# ---- strategy / speed ----
# crossover = slow trend trades (few signals) | scalp = active short-term trader
# (many quick entries, tight stop-loss/take-profit). For "مضارب" use scalp + a
# short INTERVAL (5m/1m) + a low POLL_SECONDS.
STRATEGY=crossover
INTERVAL=1h              # for scalping use 5m or 1m
HISTORY=500              # candles fetched per symbol for backtest/ML

# ---- sizing & risk ----
QUOTE_PER_TRADE=15       # quote spent per buy (e.g. USDT)
MAX_OPEN_POSITIONS=3
DAILY_LOSS_LIMIT=0       # 0 = off; e.g. 50 = halt new buys after losing 50 quote/day
# Trailing stop: ride the rise, sell when price pulls back this % from its peak.
# 0 = off (use the optimizer's fixed take-profit). e.g. 2 = sell on a 2% pullback.
TRAILING_STOP_PCT=0
PAPER_EQUITY=1000        # starting equity for dryrun accounting only

# ---- publish dashboard + durable state backup (optional) ----
# Lets you watch the bot from anywhere via crypto/bot.html, AND backs up
# state.json to GitHub (restored on boot) so the bot keeps open positions on a
# stateless cloud host. Pushed to a SEPARATE branch so it won't spam rebuilds.
PUBLISH_DASHBOARD=false
GITHUB_TOKEN=             # fine-grained PAT with Contents: Read & Write on the repo
GH_REPO=salem0557/cloude
PUBLISH_BRANCH=bot-live
PUBLISH_SECONDS=60       # how often to push the snapshot

# ---- timing / self-learning ----
POLL_SECONDS=30           # how often to re-check the market & re-learn
REALTIME_LEARNING=true    # true = re-tune params EVERY cycle (real-time).
                          # false = use the slower OPTIMIZE_HOURS schedule.
OPTIMIZE_HOURS=2          # only used when REALTIME_LEARNING=false
ML_RETRAIN_MINUTES=10     # how often to retrain the ML model (0 = every cycle)
