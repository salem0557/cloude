# Copy this file to  bot/.env  and fill in your values.
# .env is git-ignored so your keys never get committed.

# dryrun = no real orders (safe) | testnet = fake money | live = REAL money
BOT_MODE=dryrun

# Only needed for testnet/live. Create a TRADE-ONLY key with withdrawals DISABLED.
# Testnet keys come from https://testnet.binance.vision (not your real account).
BINANCE_API_KEY=
BINANCE_API_SECRET=

# What and how to trade
SYMBOL=BTCUSDT
INTERVAL=1h
FAST=7
SLOW=25
QUOTE_PER_TRADE=15      # how much quote currency (e.g. USDT) to spend per buy
POLL_SECONDS=60         # how often to re-check the market
STOP_LOSS_PCT=0         # 0 = off; e.g. 5 = sell if price drops 5% below entry
