# Copy this file to  bot/.env  and fill in your values.
# .env is git-ignored so your keys never get committed.

# Manual-sell button: the live monitor (your Railway URL) shows a "بيع" button
# next to each open position so you can market-sell by hand if needed. Set a
# token to require it before a sell is accepted (recommended since the URL is
# public). Enter the same token once in the dashboard field. Empty = no token.
# MONITOR_TOKEN=choose-a-secret

# ---- cloud hosting (Railway/Render/VPS) ----
# PORT is set automatically by the host; the bot then serves a web monitor
# (dashboard + live logs) at that URL. Locally you can set it to e.g. 8000.
# PORT=8000
# DATA_DIR keeps state/models/trades on a persistent volume across redeploys.
# DATA_DIR=/data

# ---- mode ----
# dryrun = no real orders (safe) | testnet = fake money | live = REAL money
BOT_MODE=dryrun

# LIVE safety latch — live mode refuses to start unless this is set exactly:
# CONFIRM_LIVE=I_UNDERSTAND_THE_RISK

# ---- API keys (only for testnet/live) ----
# Create a TRADE-ONLY key with WITHDRAWALS DISABLED and IP restriction ON.
# Testnet keys come from https://testnet.binance.vision (not your real account).
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- what to trade ----
# Fixed basket (used when AUTO_UNIVERSE=false).
SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT
TOP_N=5

# AUTO_UNIVERSE: scan ALL tradable USDT pairs instead of the fixed basket.
# The bot discovers every USDT pair, scans them in rotating batches, keeps a
# rolling SHORTLIST of the best performers, deep-optimizes those, and trades
# the best TOP_N — without hammering Binance rate limits. ON by default so the
# entry funnel is wide enough for the 6 quality gates to still find trades.
AUTO_UNIVERSE=true
MIN_QUOTE_VOLUME=20000000  # ignore illiquid coins (24h volume below this). 0 = all
MAX_UNIVERSE=250           # cap the universe size (raise toward 900 for everything)
SCAN_BATCH=30              # pairs quick-scanned per cycle (rotates through all)
SHORTLIST=12               # best scanned pairs to deep-optimize & pick TOP_N from

# ---- strategy / speed ----
# STRATEGY selects how the bot trades:
#   auto (default) = the optimizer competes the WHOLE basket (crossover, scalp,
#       bollinger, bollinger_breakout, macd, rsi_meanrev, donchian, ema_ribbon,
#       stochastic, zscore) and picks the best one PER COIN, validated
#       out-of-sample. This is the strongest setting — each coin gets the
#       approach that actually has an edge on it.
#   <name>        = force a single strategy from that list (e.g. scalp).
STRATEGY=auto
INTERVAL=1h              # for scalping use 5m or 1m
# Auto-revert safety (only relevant when STRATEGY=scalp is FORCED): if forced
# scalp is net-negative over this many CLOSED trades, revert to crossover. 0=off.
STRATEGY_AUTO_REVERT_TRADES=12
HISTORY=1000            # candles fetched per symbol for backtest/ML. More history
                        # = a bigger held-out set = a more trustworthy ML accuracy.
                        # 1000 is recommended now that ML is scored out-of-sample.

# ---- sizing & risk ----
QUOTE_PER_TRADE=15       # quote spent per buy (e.g. USDT)
MAX_OPEN_POSITIONS=5
DAILY_LOSS_LIMIT=0       # 0 = off; e.g. 50 = halt new buys after losing 50 quote/day
# Trailing stop: ride the rise, sell when price pulls back this % from its peak.
# 0 = off (use the optimizer's fixed take-profit). e.g. 2 = sell on a 2% pullback.
TRAILING_STOP_PCT=0

# ---- fixed exit rules (override the optimizer's auto-tuned values) ----
# 0 = let the optimizer choose. Set both to force e.g. "sell at +4% or -1%".
TAKE_PROFIT_PCT=0        # sell when a position is up this %  (ignored if trailing on)
STOP_LOSS_PCT=0          # sell when a position is down this %

# Min ML "up" probability to allow a buy. Lower = more (riskier) trades.
# The ML model now reports HONEST out-of-sample accuracy (measured on candles it
# never trained on). If a coin's model has no real edge it is ignored entirely,
# so the bot falls back to the technical signal instead of trusting a fluke.
ML_BUY_THRESHOLD=0.55

# Escape filter: skip entry if the bid/ask spread is wider than this % (a wide
# spread = illiquid coin you can't exit cleanly). 0 = off. 0.5 = sensible.
MAX_SPREAD_PCT=0.5

# News gate: block buys on strong negative crypto news. Set false to trade
# through it (recommended for aggressive scalping; a deployed news.json can be
# stale and would otherwise block all trading).
NEWS_GATE=true

# Smart-money gate (FREE alt-data): Binance publishes the ratio of TOP traders
# who are net long vs short on each coin. When ON, the bot only confirms a buy
# if that ratio is at least SMART_MONEY_MIN — i.e. smart money isn't heavily
# short. Coins without a futures market are ignored (treated as neutral). The
# ratio is logged on each entry so you can see typical values and tune the
# threshold. >1 = top traders net long; <1 = net short.
SMART_MONEY_GATE=true
SMART_MONEY_MIN=0.8

# Pause switch: true = open NO new positions, but keep managing and exiting
# the ones already open (stop-loss / trailing / take-profit all still run).
# Use this to halt buying without killing the service or stranding a position.
PAUSE_TRADING=false

# ---- market-trend filter (anti-bear) ----
# A long-only bot bleeds when it keeps buying dips in a falling market. When ON,
# the bot opens NO new longs while BTC is below its long moving average (bear),
# and resumes automatically when BTC reclaims it (bull). Exits still run always.
MARKET_TREND_FILTER=true
MARKET_TREND_SYMBOL=BTCUSDT
MARKET_TREND_MA=200        # MA length (200 = the classic trend line)
# Judge the broad trend on its OWN timeframe, NOT the fast trading INTERVAL.
# On a 5m INTERVAL, MA200 of 5m candles is only ~16h — too noisy, it flips
# bull/bear on every wiggle and needlessly pauses buying. 30m → MA200 ≈ 4 days
# = a real trend; 1h → ≈ 8 days (steadier still).
MARKET_TREND_INTERVAL=30m

# Coin-quality filter: skip auto-discovered coins whose recent per-bar
# volatility (std-dev of returns) exceeds this %. Filters degenerate microcaps
# that whipsaw stops and over-fit the optimizer. 0 = off. Only affects
# AUTO_UNIVERSE scanning (your fixed SYMBOLS basket is never filtered out).
MAX_VOLATILITY_PCT=6

# Maturity filter: keep brand-new listings out of the auto universe (their tiny
# history can't be back-tested honestly and they're the most manipulation-prone).
# Value = minimum days the pair must have traded. 0 = off. Only affects
# AUTO_UNIVERSE scanning; your fixed SYMBOLS basket is never filtered out.
MIN_LISTING_DAYS=30

# ---- extra free learning signals (no API key needed) ----
# Derivatives gate (Binance futures data): vetoes a buy when funding is
# euphoric/crowded-long (high reversal risk). Funding + open-interest + taker
# buy/sell flow are also logged so you can see the leverage/flow context.
DERIVATIVES_GATE=true
# ATR volatility stop: stop distance = max(tuned %, ATR×mult). 0 = off (fixed %
# only). ~1.5–2.5 adapts the stop to each coin's real volatility so normal
# noise doesn't whipsaw you out. Needs high/low candles (fetched automatically).
ATR_STOP_MULT=0
ATR_PERIOD=14
# Note: candle VOLUME and BTC DOMINANCE (CoinGecko) are now used automatically —
# volume/high/low feed the ML model as new features; high BTC dominance shrinks
# alt position size via the market-regime risk multiplier. No config needed.

# ---- extra free intelligence sources (make the bot smarter, ~$0) ----
# All of these degrade gracefully: with no key/network they simply stay neutral
# and the bot trades exactly as before.
#
# 1) LIVE NEWS FEED (CryptoCompare, free, no key) — keeps the news gate fresh
#    instead of relying only on a static news.json that can go stale on deploy.
NEWS_FEED_LIVE=true
# CRYPTOCOMPARE_KEY=        # optional, only raises the free rate limit
#
# 2) AI NEWS SENTIMENT (free LLM) — a small model READS the headlines and scores
#    market sentiment (-1..1), far better than keyword counting. Set ONE key:
# GEMINI_API_KEY=          # Google AI Studio (free): https://aistudio.google.com/apikey
# GROQ_API_KEY=            # Groq (free):            https://console.groq.com/keys
# LLM_PROVIDER=gemini      # gemini | groq (auto-detected from whichever key is set)
# GEMINI_MODEL=gemini-flash-latest
# GROQ_MODEL=llama-3.3-70b-versatile
#
# 3) ON-CHAIN RISK (DeFiLlama, free, no key) — total DeFi TVL trend. A sharp
#    multi-day capital drain shrinks position size (risk-off). Automatic, no
#    config; folded into the market-regime risk multiplier.
#
# 4) SOCIAL MOMENTUM (CoinGecko trending, free, no key) — logs when a coin we're
#    buying is also trending socially. Confirming signal only, never blocks a buy.
SOCIAL_SIGNAL=true

PAPER_EQUITY=1000        # starting equity for dryrun accounting only

# ---- publish dashboard + durable state backup (optional) ----
# Lets you watch the bot from anywhere via crypto/bot.html, AND backs up
# state.json to GitHub (restored on boot) so the bot keeps open positions on a
# stateless cloud host. Pushed to a SEPARATE branch so it won't spam rebuilds.
PUBLISH_DASHBOARD=false
GITHUB_TOKEN=             # fine-grained PAT with Contents: Read & Write on the repo
GH_REPO=salem0557/cloude
PUBLISH_BRANCH=bot-live
PUBLISH_SECONDS=60       # how often to push the snapshot

# ---- timing / self-learning ----
POLL_SECONDS=30           # how often to manage positions / react to price
LEARN_SECONDS=1800        # how often to run the heavy scan+optimize (decoupled
                          # from POLL_SECONDS so exits stay fast). Keep this LARGE
                          # (~30m+): re-tuning every few seconds just chases noise
                          # and makes the picked strategy/params thrash. Exits
                          # still react within POLL_SECONDS regardless.
REALTIME_LEARNING=true    # true = re-tune on the LEARN_SECONDS cadence.
                          # false = use the slower OPTIMIZE_HOURS schedule.
OPTIMIZE_HOURS=2          # only used when REALTIME_LEARNING=false
ML_RETRAIN_MINUTES=5      # how often to retrain the ML model (0 = every cycle).
                          # 5 keeps the honest accuracy fresh without much load.
